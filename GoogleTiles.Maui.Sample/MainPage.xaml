<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:gt="clr-namespace:GoogleTiles.Maui.Controls;assembly=GoogleTiles.Maui"
             xmlns:vm="clr-namespace:GoogleTiles.Maui.Sample.ViewModels"
             x:DataType="vm:MainViewModel"
             x:Class="GoogleTiles.Maui.Sample.MainPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <gt:GoogleTilesView Grid.Row="0" ZoomLevel="12" Center="40.7608, -111.8910" MapType="{Binding MapType}" MapTheme="{Binding Theme}"/>
        <StackLayout Grid.Row="1" Orientation="Horizontal" Spacing="5">
            <Button Text="Cycle Map Type" Command="{Binding CycleMapTypeCommand}"/>
            <Button Text="Toggle theme" Command="{Binding ToggleNightMode}" IsEnabled="{Binding IsNightEnabled}"/>
        </StackLayout>
    </Grid>
</ContentPage>
